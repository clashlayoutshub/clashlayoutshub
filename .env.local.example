GEMINI_API_KEY=your_gemini_api_key_here

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset
# For signed uploads (recommended — get from Cloudinary dashboard → Settings → API Keys)
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

ADMIN_PASSWORD=your_secure_admin_password
NEXT_PUBLIC_SITE_URL=https://clashlayoutshub.com

# Advertisement control — set to 'true' to show ads, 'false' to hide them
NEXT_PUBLIC_SHOW_ADS=false

# Supabase — required for all data operations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
